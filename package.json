{
  "name": "@k-dang/ports-cli",
  "version": "0.1.3",
  "module": "index.ts",
  "type": "module",
  "description": "Interactive CLI for finding common open localhost dev ports and closing the processes that own them.",
  "repository": "github:k-dang/ports-cli",
  "bin": {
    "ports": "./dist/cli.js",
    "ports-cli": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js"
  ],
  "scripts": {
    "start": "bun run index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build:npm": "bun build ./index.ts --target=node --outfile dist/cli.js",
    "prepublishOnly": "bun run build:npm"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0"
  }
}
